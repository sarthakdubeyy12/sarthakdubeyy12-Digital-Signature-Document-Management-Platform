# Application
NODE_ENV=development
PORT=5001
API_VERSION=v1

# Database
MONGODB_URI=mongodb://mongo:27017/digital-signature-platform
MONGODB_TEST_URI=mongodb://localhost:27017/digital-signature-platform-test

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Password Reset
PASSWORD_RESET_EXPIRY=1h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf
UPLOAD_PATH=./storage

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# AWS S3 (Future)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@digitalsignature.com
EMAIL_FROM_NAME=Digital Signature Platform

# Frontend URL
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FILE_ERROR=logs/error/error-%DATE%.log
LOG_FILE_COMBINED=logs/combined/combined-%DATE%.log
LOG_FILE_AUDIT=logs/audit/audit-%DATE%.log

# Admin
ADMIN_EMAIL=admin@digitalsignature.com
ADMIN_PASSWORD=Admin@123456
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator
